knitr::opts_chunk$set(echo = TRUE)
# List all CSV files in the directory
file_list <- list.files(path = "data/SuccessFailure/", pattern = "\\.csv$", full.names = TRUE)
# Read each CSV file into a list
data_list <- lapply(file_list, read.csv)
file_list <- list.files(path = "data/SuccessFailure/", pattern = "\\.csv$", full.names = TRUE)
data_list <- lapply(file_list, function(file) read.csv(file, header = TRUE))
all_data <- do.call(rbind, data_list)
str(all_data)
# Ensure logicals are treated properly
all_data$`AI Initiates` <- as.logical(all_data$`AI Initiates`)
file_list <- list.files(path = "data/SuccessFailure/", pattern = "\\.csv$", full.names = TRUE)
data_list <- lapply(file_list, function(file) {
read.csv(file, header = TRUE, check.names = FALSE, stringsAsFactors = FALSE)
})
all_data <- do.call(rbind, data_list)
str(all_data)
colnames(all_data)
# Ensure logicals are treated properly
all_data$`AI Initiates` <- as.logical(all_data$`AI Initiates`)
all_data$`User Initiates` <- as.logical(all_data$`User Initiates`)
library(ggplot2)
install.packages("ggplot2")
file_list <- list.files(path = "data/SuccessFailure/", pattern = "\\.csv$", full.names = TRUE)
data_list <- lapply(file_list, function(file) {
read.csv(file, header = TRUE, check.names = FALSE, stringsAsFactors = FALSE)
})
all_data <- do.call(rbind, data_list)
str(all_data)
colnames(all_data)
# Ensure logicals are treated properly
all_data$`AI Initiates` <- as.logical(all_data$`AI Initiates`)
all_data$`User Initiates` <- as.logical(all_data$`User Initiates`)
library(ggplot2)
# Example: Boxplot of Success by Initiator
ggplot(all_data, aes(x = `AI Initiates`, y = Success)) +
geom_boxplot() +
labs(title = "Success vs. AI Initiation", x = "AI Initiated", y = "Success Count")
