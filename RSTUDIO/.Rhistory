failures <- c(sum(all_data$Failure[all_data$AI_Initiates == TRUE]), sum(all_data$Failure[all_data$AI_Initiates == FALSE ]),sum(all_data$Failure[all_data$AI_Initiates == FALSE &all_data$Asks_for_Help == FALSE]))
failures[3] <- failures[3] + sum(all_data$Success[all_data$Asks_for_Help == 1])
